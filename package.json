{
  "name": "stirod-svg-toolkit",
  "version": "1.0.0",
  "description": "Framework agnostic SVG toolkit for generating sprites, metadata and types",
  "type": "module",
  "author": "Stirod",
  "license": "MIT",
  "keywords": [
    "svg",
    "sprite",
    "toolkit",
    "icons",
    "cli",
    "astro",
    "react",
    "vue",
    "svelte"
  ],
  "files": [
    "bin",
    "core",
    "templates",
    "dist"
  ],
  "bin": {
    "stirod-svg-toolkit": "./bin/cli.js"
  },
  "scripts": {
    "build:sprite": "node core/sprite-generator.js",
    "icons:init": "stirod-svg-toolkit init",
    "icons:build": "stirod-svg-toolkit build"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.1.3",
      "onFail": "download"
    }
  },
  "devDependencies": {
    "svgo": "^4.0.1"
  },
  "dependencies": {
    "stirod-svg-toolkit": "link:"
  }
}
